# Optional Stripe premium (set in Railway / hosting dashboard)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...   ← Dashboard → Products → Pricing → Price ID (not $9.99 or 999 cents)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Public URL of your deployed app (no trailing slash). Required for Stripe redirect URLs behind proxies.
# PUBLIC_BASE_URL=https://your-app.up.railway.app

# Secret for signing premium tokens (use a long random string in production)
# PREMIUM_JWT_SECRET=
